# Copy this file to .env and fill in your values.
# Do not commit .env to version control.

# Google Sheets
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEET_ID=
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=

# Google OAuth (Sign-in)
GOOGLE_OAUTH_CLIENT_ID=

# Admin emails (comma-separated)
ADMIN_EMAILS=


PRAYER_RECIPIENT_EMAIL=

# Optional: Share / app links (defaults used if empty)
APP_NAME=Spiritual Wisdom
APP_STORE_LINK=https://apps.apple.com/app/spiritual-wisdom
PLAY_STORE_LINK=https://play.google.com/store/apps/details?id=com.spiritualwisdom
WEB_APP_LINK=https://spiritualwisdom.app
